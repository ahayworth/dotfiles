[diff]
  algorithm = histogram
  colorMoved = zebra
[merge]
  conflictStyle = zdiff3
[rerere]
  enabled = true
[user]
	name = Andrew Hayworth
	email = ahayworth@gmail.com
[github]
	user = ahayworth
{{- if .mac }}
[credential]
	helper = osxkeychain
{{- end }}
[alias]
  st = status
  co = checkout
  me = log --pretty=oneline --author=ahayworth
[pull]
  rebase = false
[init]
  defaultBranch = main
{{- if .work }}
[url "git@github.com:"]
  insteadOf = https://github.com/
[core]
  hooksPath = /Users/andrew/.config/git/hooks
{{- end }}
