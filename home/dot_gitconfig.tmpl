[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  dark = true
[merge]
  conflictStyle = zdiff3
[user]
	name = Andrew Hayworth
	email = ahayworth@gmail.com
[push]
	default = matching
[github]
	user = ahayworth
[credential]
	helper = osxkeychain
[alias]
  st = status
  co = checkout
  me = log --pretty=oneline --author=ahayworth
[protocol]
  version = 2
[pull]
  rebase = false
[init]
  defaultBranch = main
{{- if .work }}
[url "git@github.com:"]
  insteadOf = https://github.com/
[core]
  hooksPath = /Users/andrew/.config/git/hooks
{{- end }}
