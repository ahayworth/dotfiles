#!/bin/bash
set -euo pipefail

{{- if .codespaces }}
exit 0
{{ end }}
# hash: {{ include "dot_tmux.conf.tmpl" | sha256sum }}

if [ -x ~/.tmux/plugins/tpm/bin/install_plugins ]; then
  TMUX_PLUGIN_MANAGER_PATH=~/.tmux/plugins ~/.tmux/plugins/tpm/bin/install_plugins || true
fi

if [ -n "${TMUX:-}" ]; then
  tmux source-file ~/.tmux.conf || true
fi
