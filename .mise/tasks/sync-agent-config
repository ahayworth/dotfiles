#!/bin/bash
# Sync agent config templates (managed by chezmoi at ~/.config/agent-templates/)
# into the current project directory.
#
# This is a skeleton to be fleshed out as the agent config story matures.

set -euo pipefail

TEMPLATE_DIR="${HOME}/.config/agent-templates"

if [ ! -d "$TEMPLATE_DIR" ]; then
  echo "No agent templates found at $TEMPLATE_DIR"
  exit 0
fi

echo "Agent config sync: not yet implemented"
echo "Templates would be sourced from: $TEMPLATE_DIR"
